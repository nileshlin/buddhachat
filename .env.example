# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meditation_db

# Redis (Celery broker/result backend)
REDIS_URL=redis://localhost:6379/0

# Authentication configuration
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_bytes

# Google authentication
GOOGLE_CLIENT_ID=<your-ios-client-id>.apps.googleusercontent.com
APPLE_BUNDLE_ID=
APPLE_PUBLIC_KEY_URL=https://appleid.apple.com/auth/keys
APPLE_ISSUER=https://appleid.apple.com

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=1ok9oo8w0A9iIezS9imJ
ELEVENLABS_MODEL=eleven_monolingual_v1

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=

# AWS Configuration (S3 and SES)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-2

AWS_S3_BUCKET=your_s3_bucket_name
AWS_S3_PRESIGN_EXPIRES_SECONDS=3600
SES_SENDER_EMAIL=noreply@yourdomain.com

# Support (iOS issue reporting)
SUPPORT_EMAIL=info@buddhachat.com
